# ==============================================================================
# H-1B Analysis Pipeline - Git Ignore
# ==============================================================================
# Large data files are stored in Google Drive (see README.md for links)
# ==============================================================================

# Data files (too large for git)
data/raw/*
data/intermediate/*
data/processed/*
data/*.zip
data/h1b_analysis_pipeline_data/
data/output/

# Keep README files that explain where to get data
!data/raw/README.md
!data/intermediate/README.md
!data/processed/README.md

# R files
.Rhistory
.RData
.Rproj.user
*.Rproj
Rplots.pdf

# Output files (can be regenerated or stored in Google Drive)
output/figures/*
output/tables/*

# Keep README files in output directories
!output/figures/README.md
!output/tables/README.md

# Keep directory structure
!data/raw/.gitkeep
!data/intermediate/.gitkeep
!data/processed/.gitkeep
!output/figures/.gitkeep
!output/tables/.gitkeep

# OS files
.DS_Store
.DS_Store?
._*
Thumbs.db
__MACOSX/

# Temporary files
*.tmp
*.log
*.bak
*~
